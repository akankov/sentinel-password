{
  "name": "@sentinel-password/breach",
  "version": "0.2.1",
  "type": "module",
  "description": "Have I Been Pwned breach checking via k-anonymity for sentinel-password. Zero runtime dependencies; ≤ 10 KB gzipped (CI enforced).",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "password",
    "breach",
    "hibp",
    "haveibeenpwned",
    "pwned-passwords",
    "k-anonymity",
    "security",
    "typescript",
    "zero-dependency"
  ],
  "author": "Aleksei Kankov <akankov@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akankov/sentinel-password",
    "directory": "packages/breach"
  },
  "homepage": "https://akankov.github.io/sentinel-password/",
  "bugs": {
    "url": "https://github.com/akankov/sentinel-password/issues"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
