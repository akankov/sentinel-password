{
  "name": "@sentinel-password/react",
  "version": "1.1.1",
  "type": "module",
  "description": "React hooks and components for @sentinel-password/core - password validation made simple",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "password",
    "validation",
    "react",
    "hooks",
    "components",
    "typescript",
    "password-validator",
    "password-strength",
    "react-hooks"
  ],
  "author": "Aleksei Kankov <akankov@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akankov/sentinel-password",
    "directory": "packages/react"
  },
  "homepage": "https://akankov.github.io/sentinel-password/",
  "bugs": {
    "url": "https://github.com/akankov/sentinel-password/issues"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@sentinel-password/core": "workspace:*"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
